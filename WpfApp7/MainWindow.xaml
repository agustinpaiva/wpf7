<Window x:Class="WpfApp7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp7"
        mc:Ignorable="d"
        Title="Punto de Venta - Almacén de Barrio" Height="600" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel de Catálogo (Izquierda) -->
        <DockPanel Grid.Column="0">
            <TextBlock Text="Catálogo de Productos" DockPanel.Dock="Top" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="Buscar:"/>
                <TextBox x:Name="TxtSearch" TextChanged="TxtSearch_TextChanged" Height="30" VerticalContentAlignment="Center" FontSize="14"/>
            </StackPanel>

            <ListBox x:Name="LstProducts" ItemsSource="{Binding FilteredProducts}" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5" Width="350">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Price, StringFormat='Price: ${0}'}" Foreground="Gray"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="Agregar" Click="BtnAddToCart_Click" Padding="10,5" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Divisor -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#EEE"/>

        <!-- Panel de Carrito (Derecha) -->
        <DockPanel Grid.Column="2" Margin="10,0,0,0">
            <TextBlock Text="Venta Actual" DockPanel.Dock="Top" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- Botones de Acción Inferiores -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Separator Margin="0,0,0,10"/>
                <Grid>
                    <TextBlock Text="TOTAL:" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Total, StringFormat='${0:N2}'}" FontSize="36" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Right"/>
                </Grid>
                <Button Content="FINALIZAR VENTA" Click="BtnFinalizeSale_Click" Height="60" Margin="0,10,0,0" FontSize="20" FontWeight="Bold" Background="#2196F3" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <DataGrid x:Name="DgCart" ItemsSource="{Binding Cart}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" FontSize="14" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Product.Name}" Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Product.Price, StringFormat='${0}'}" Width="80"/>
                    <DataGridTextColumn Header="Cant." Binding="{Binding Quantity}" Width="60"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat='${0:N2}'}" Width="100"/>
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Quitar" Click="BtnRemoveFromCart_Click" Background="#f44336" Foreground="White" BorderThickness="0" Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
