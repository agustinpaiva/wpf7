<Window x:Class="WpfApp7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp7"
        mc:Ignorable="d"
        Title="TPV Almacén - Dark Mode" Height="650" Width="1100" WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Window.Resources>
        <!-- Estilo para los textos -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <!-- Estilo para el DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#252525"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
            <Setter Property="VerticalGridLinesBrush" Value="#333"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel de Catálogo (Izquierda) -->
        <DockPanel Grid.Column="0">
            <TextBlock Text="Catálogo de Productos" DockPanel.Dock="Top" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#BB86FC"/>

            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                <TextBlock Text="Buscar producto:" Margin="0,0,0,5" Foreground="#888"/>
                <TextBox x:Name="TxtSearch" TextChanged="TxtSearch_TextChanged" Height="35" 
                         VerticalContentAlignment="Center" FontSize="16" 
                         Background="#2D2D2D" Foreground="White" BorderBrush="#444" CaretBrush="White"/>
            </StackPanel>

            <ListBox x:Name="LstProducts" ItemsSource="{Binding FilteredProducts}" 
                     Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="0,0,0,10" BorderBrush="#333" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" Foreground="White"/>
                                    <TextBlock Text="{Binding Price, StringFormat='${0:N2}'}" FontSize="18" Foreground="#03DAC6" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="+" Click="BtnAddToCart_Click" 
                                        Width="45" Height="45" FontSize="20" FontWeight="Bold"
                                        Background="#BB86FC" Foreground="#121212" BorderThickness="0">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="22"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Divisor vertical -->
        <Rectangle Grid.Column="1" Width="1" Fill="#333" HorizontalAlignment="Center" Margin="0,10"/>

        <!-- Panel de Carrito (Derecha) -->
        <DockPanel Grid.Column="2" Margin="10,0,0,0">
            <TextBlock Text="Venta en curso" DockPanel.Dock="Top" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#03DAC6"/>

            <!-- Panel Inferior de Total -->
            <Border DockPanel.Dock="Bottom" Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,15,0,0" BorderBrush="#333" BorderThickness="1">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="TOTAL A COBRAR" FontSize="14" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Total, StringFormat='${0:N2}'}" FontSize="42" FontWeight="Bold" Foreground="#03DAC6" HorizontalAlignment="Right"/>
                    </Grid>
                    <Button Content="PROCESAR PAGO" Click="BtnFinalizeSale_Click" 
                            Height="65" Margin="0,15,0,0" FontSize="22" FontWeight="Bold" 
                            Background="#03DAC6" Foreground="#121212" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <DataGrid x:Name="DgCart" ItemsSource="{Binding Cart}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                      FontSize="15" SelectionMode="Single" BorderThickness="1" GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Detalle" Binding="{Binding Product.Name}" Width="*"/>
                    <DataGridTextColumn Header="P. Unit" Binding="{Binding Product.Price, StringFormat='${0}'}" Width="100"/>
                    <DataGridTextColumn Header="Cant." Binding="{Binding Quantity}" Width="70"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat='${0:N2}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#03DAC6"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Click="BtnRemoveFromCart_Click" 
                                        Background="#CF6679" Foreground="White" FontWeight="Bold"
                                        BorderThickness="0" Width="30" Height="30">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="15"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
